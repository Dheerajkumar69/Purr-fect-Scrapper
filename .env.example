# ─── Core ────────────────────────────────────────────────
LOG_LEVEL=INFO
SCRAPER_OUTPUT_DIR=/app/output
ALLOWED_ORIGINS=*

# ─── Celery (Redis) ─────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Proxy pool (comma-separated, optional) ─────────────
# SCRAPER_PROXIES=http://user:pass@proxy1:8080,http://proxy2:8080

# ─── AI Assist engine (optional) ────────────────────────
AI_SCRAPER_ENABLED=0
# AI_API_BASE=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# ─── Job queue limits ───────────────────────────────────
MAX_CONCURRENT_JOBS=4
MAX_QUEUED_JOBS=100

# ─── Confidence gate ────────────────────────────────────
CONFIDENCE_RESCRAPE_THRESHOLD=0.35

# ─── Crawl checkpointing ────────────────────────────────
CRAWL_CHECKPOINT_INTERVAL=25

# ─── Circuit breaker ────────────────────────────────────
CIRCUIT_BREAKER_RATIO=0.70
CIRCUIT_BREAKER_MIN_ENGINES=3

# ─── API Key gating (optional) ──────────────────────────
# SCRAPER_API_KEY=your-secret-key
